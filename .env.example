# Server
SERVER_PORT=8080

# JWT
JWT_SECRET=change-me-with-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION_MILLIS=86400000

# H2 / local development
H2_URL=jdbc:h2:file:./data/firmadb-dev
H2_USER=sa
H2_PASSWORD=

# PostgreSQL
POSTGRES_URL=jdbc:postgresql://localhost:5432/firma_db
POSTGRES_USER=firma_user
POSTGRES_PASSWORD=firma_password

# Generic datasource for QA/PROD
DATASOURCE_URL=jdbc:postgresql://localhost:5432/firma_db
DATASOURCE_DRIVER=org.postgresql.Driver
DATASOURCE_USER=firma_user
DATASOURCE_PASSWORD=firma_password
QA_DATASOURCE_URL=jdbc:h2:file:./data/firmadb-qa
QA_DATASOURCE_DRIVER=org.h2.Driver
QA_DATASOURCE_USER=sa
QA_DATASOURCE_PASSWORD=

# Signio mock/real integration placeholders
SIGNIO_URL=https://api.signio.com
SIGNIO_TOKEN=replace-with-signio-token
SIGNIO_WEBHOOK_SECRET=replace-with-shared-webhook-secret
SIGNIO_WEBHOOK_URL=https://your-domain.example.com/webhooks/signio

# OnBase future integration placeholders
ONBASE_URL=https://onbase.example.com
ONBASE_TOKEN=replace-with-onbase-token
